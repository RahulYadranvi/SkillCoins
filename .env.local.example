# ─── Supabase ───────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → Your Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here   # NEVER expose this to client

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000               # Change to your domain in production
NEXT_PUBLIC_APP_NAME=SkillCoins

# ─── Upstash Redis (Rate Limiting) ──────────────────────────────────────────
# Get from: https://upstash.com → Free tier → Create Redis DB
UPSTASH_REDIS_REST_URL=your_upstash_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ─── Google AdSense ─────────────────────────────────────────────────────────
# Add after AdSense approval
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=ca-pub-XXXXXXXXXXXXXXXX

# ─── Razorpay (Payouts to users) ────────────────────────────────────────────
# Get from: https://razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_secret_here

# ─── Resend (Transactional Email) ───────────────────────────────────────────
# Get from: https://resend.com → Free tier
RESEND_API_KEY=re_XXXXXXXXXX

# ─── Admin ──────────────────────────────────────────────────────────────────
# Your Supabase user ID — gets admin privileges
ADMIN_USER_ID=your_supabase_user_id_here
